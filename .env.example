PORT=3000
APP_URL=https://TU-APP.onrender.com
APP_TOKEN=cambia-este-token-admin
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/whatsapp_bot?retryWrites=true&w=majority
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
HEADLESS=true
BOT_DEFAULT_PROMPT=Eres un asistente profesional de WhatsApp. Responde en español claro, breve y útil. Si te faltan datos, dilo con honestidad y ofrece seguimiento humano.
REPLY_COOLDOWN_MS=6000
IGNORE_GROUPS=true
IGNORE_STATUS=true
REMOTE_BACKUP_INTERVAL_MS=300000
TEMP_AUTH_DIR=./tmp-auth
HISTORY_LIMIT=250
