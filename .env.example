NODE_ENV=production
APP_URL=https://whatsapp-render-free.onrender.com
APP_TOKEN=CAMBIA_ESTE_TOKEN
OPENAI_API_KEY=PEGA_TU_API_KEY
OPENAI_MODEL=gpt-5.4-mini
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/whatsappbot?retryWrites=true&w=majority
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
HEADLESS=true
REPLY_COOLDOWN_MS=6000
IGNORE_GROUPS=true
IGNORE_STATUS=true
REMOTE_BACKUP_INTERVAL_MS=300000
TEMP_AUTH_DIR=./tmp-auth
HISTORY_LIMIT=250
INIT_TIMEOUT_MS=120000
BOT_DEFAULT_PROMPT=Eres un asistente profesional de WhatsApp. Responde en español claro, breve y útil. Si te faltan datos, dilo con honestidad y ofrece seguimiento humano.
